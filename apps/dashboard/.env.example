# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# API Service
NEXT_PUBLIC_DISTRIBUTE_API_URL=https://api.distribute.you
ADMIN_DISTRIBUTE_API_KEY=your-admin-key-here

# Key Service
KEY_SERVICE_URL=https://key-service.railway.internal
KEY_SERVICE_API_KEY=your-key-service-api-key

# Content Generation Service
CONTENT_GENERATION_SERVICE_URL=https://content-generation-service.railway.internal
CONTENT_GENERATION_SERVICE_API_KEY=your-content-generation-service-api-key

# Chat Service
CHAT_SERVICE_URL=https://chat-service.railway.internal
CHAT_SERVICE_API_KEY=your-chat-service-api-key

# Platform Keys (registered with key-service at startup)
ANTHROPIC_API_KEY=sk-ant-...
APOLLO_API_KEY=your-apollo-key
INSTANTLY_API_KEY=your-instantly-key
FIRECRAWL_API_KEY=your-firecrawl-key
GEMINI_API_KEY=your-gemini-key
POSTMARK_API_KEY=your-postmark-key
POSTMARK_BROADCAST_STREAM_ID=your-broadcast-stream-id
POSTMARK_INBOUND_STREAM_ID=your-inbound-stream-id
POSTMARK_TRANSACTIONAL_STREAM_ID=your-transactional-stream-id
POSTMARK_FROM_ADDRESS=noreply@distribute.you
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
