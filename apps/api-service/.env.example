# Clerk (for JWT verification)
CLERK_SECRET_KEY=sk_live_...

# Sentry (error tracking)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Internal services (Railway private networking)
EMAILGENERATION_SERVICE_URL=http://emailgeneration-service.railway.internal
CLIENT_SERVICE_URL=http://client-service.railway.internal

# External services (public URLs, need API keys)
BRAND_SERVICE_URL=https://brand.mcpfactory.org
LEAD_SERVICE_URL=https://lead.mcpfactory.org
KEY_SERVICE_URL=https://key.mcpfactory.org
REPLY_QUALIFICATION_SERVICE_URL=https://reply-qualification.mcpfactory.org
SCRAPING_SERVICE_URL=https://scraping.mcpfactory.org
LIFECYCLE_EMAILS_SERVICE_URL=https://lifecycle-emails.mcpfactory.org
EMAIL_SENDING_SERVICE_URL=https://email-sending.mcpfactory.org

# Service-to-service auth for external services
BRAND_SERVICE_API_KEY=your-brand-service-api-key
LEAD_SERVICE_API_KEY=your-lead-service-api-key
CAMPAIGN_SERVICE_API_KEY=your-campaign-service-api-key
KEY_SERVICE_API_KEY=your-key-service-api-key
REPLY_QUALIFICATION_SERVICE_API_KEY=your-reply-qualification-api-key
SCRAPING_SERVICE_API_KEY=your-scraping-service-api-key
