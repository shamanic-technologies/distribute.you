{
  "name": "distribute",
  "version": "0.1.0",
  "private": true,
  "description": "The DFY, BYOK MCP Platform",
  "author": "distribute",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shamanic-technologies/distribute.you.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:dashboard": "pnpm --filter @distribute/dashboard dev",
    "dev:docs": "pnpm --filter @distribute/docs dev",
    "dev:landing": "pnpm --filter @distribute/landing dev",
"dev:sales-cold-emails-landing": "pnpm --filter @distribute/sales-cold-emails-landing dev",
    "build": "turbo build",
    "build:dashboard": "pnpm --filter @distribute/dashboard build",
    "build:docs": "pnpm --filter @distribute/docs build",
    "build:landing": "pnpm --filter @distribute/landing build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "publish-packages": "turbo build --filter='./packages/*' && changeset publish",
    "generate:readme": "pnpm --filter @distribute/content generate:readme"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "@changesets/cli": "^2.27.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
